[global]
    font = Cascadia Code NF
    corner_radius = 8
    transparency = 10
    markup = yes
    plain_text = no
    format = "<b>%s</b>\n%b"
    sort = no
    indicate_hidden = yes
    alignment = center
    bounce_freq = 0
    show_age_threshold = -1
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = yes
    hide_duplicate_count = yes
    geometry = "300x50-15+49"
    shrink = no
    idle_threshold = 0
    monitor = 0
    follow = none
    sticky_history = yes
    history_length = 15
    show_indicators = yes
    line_height = 3
    separator_height = 2
    padding = 6
    horizontal_padding = 6
    separator_color = frame
    startup_notification = false
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab
    icon_position = off
    max_icon_size = 80
    icon_path = /usr/share/icons/Paper/16x16/mimetypes/:/usr/share/icons/Paper/48x48/status/:/usr/share/icons/Paper/16x16/devices/:/usr/share/icons/Paper/48x48/notifications/:/usr/share/icons/Paper/48x48/emblems/
    frame_width = 2

[play_sound]
    summary = "*"
    script = ~/bin/play-notification

[urgency_low]
    background = "{{colors.terminal.background.hex}}"
    foreground = "{{colors.terminal.foreground.hex}}"
    frame_color = "{{colors.secondary.hex}}"
    timeout = 0

[urgency_normal]
    background = "{{colors.terminal.background.hex}}"
    foreground = "{{colors.terminal.foreground.hex}}"
    frame_color = "{{colors.primary.hex}}"
    timeout = 0

[urgency_critical]
    background = "{{colors.terminal.background.hex}}"
    foreground = "{{colors.terminal.foreground.hex}}"
    frame_color = "{{colors.terminal.normal.red.hex}}"
    timeout = 0
