#!/bin/bash

path=$(find "$HOME/pictures/wallpaper" -type f | shuf -n 1)

if [[ ! -f "$path" ]]; then
    echo "Error: "$path" is not a valid file"
    exit 1
fi

echo "New wallpaper: $path"

ln -sf "$path" "$HOME/pictures/wallpaper/current.local"

"$HOME/bin/runbg" "$HOME/bin/process-restart" hyprpaper
