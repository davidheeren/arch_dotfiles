#!/bin/bash

path="$1"

dir="$HOME/pictures/wallpaper" 

if [[ -z "$path" ]]; then
    path=$(find "$dir" -type f -printf "%f\n" | "$HOME/bin/process-toggle" wofi -S dmenu -p wallpaper)
    path="$dir/$path"
fi

if [[ ! -f "$path" ]]; then
    echo "Error: "$path" is not a valid file"
    exit 1
fi

ln -sf "$path" "$HOME/pictures/wallpaper/current.local"

"$HOME/bin/runbg" "$HOME/bin/process-restart" hyprpaper
