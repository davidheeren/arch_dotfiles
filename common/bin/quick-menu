#!/bin/bash

declare -A actions

actions['services/wifi']="kitty nmtui"
actions['services/bluetooth']="kitty bluetui"
actions['services/audio']="kitty wiremix"
actions['services/process-monitor']="kitty btm"
actions['system/suspend']="systemctl suspend"
actions['system/reboot']="systemctl reboot"
actions['system/shutdown']="systemctl poweroff"
actions['system/lock']="hyprlock"
actions['system/sleep']="hyprlock & disown && systemctl suspend"
actions['system/exit']="hyprctl dispatch 'hl.dsp.exit()'"
actions['wallpaper/set']="$HOME/bin/wallpaper-set"
actions['colorscheme/set']="$HOME/bin/colorscheme-set"
actions['information/keybinds']="hyprbind -d | wofi -S dmenu"

choice=$(printf '%s\n' "${!actions[@]}" | "$HOME/bin/process-toggle" wofi -S dmenu -p action)
[[ -n "$choice" ]] && eval "${actions[$choice]}"
