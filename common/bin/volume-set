#!/bin/bash

msgTag="volume"

case "$1" in
    up)
        wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
        ;;
    down)
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
        ;;
    mute)
        wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
        ;;
esac

status=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
volume=$(echo $status | awk '{printf $2 * 100}')

if [[ $status == *MUTED* ]]; then
    dunstify -u low -r 111 -t 750 -a "silent" "Volume [Muted]: ${volume}%"
else
    dunstify -u low -r 111 -t 750 -a "silent" "Volume: ${volume}%"
fi
