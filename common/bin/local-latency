#!/bin/bash

# source: https://daniel.haxx.se/blog/2010/12/14/add-latency-to-localhost

latency="${2:-100}"
loss_percent="${3:-10}"

if [[ "$1" == "start" ]]; then
    sudo tc qdisc add dev lo root handle 1:0 netem delay "${latency}msec" loss "${loss_percent}%"
elif [[ "$1" == "reset" ]]; then
    sudo tc qdisc del dev lo root
else
    echo "opts: 'start', 'reset'"
fi
